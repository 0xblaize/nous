# ─────────────────────────────────────────────────────────────
#  Nous — single project-wide environment file
#  Copy to .env and fill in. Read by BOTH the backend (config.py)
#  and the frontend (Vite, via envDir pointing at the repo root).
# ─────────────────────────────────────────────────────────────

# --- API keys (backend) ---
# The app runs without them (built-in stub script), but real
# generation needs at least one.
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Model overrides (backend, optional) ---
# CLAUDE_MODEL=claude-sonnet-5
# CLAUDE_FALLBACK_MODEL=claude-haiku-4-5
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_WHISPER_MODEL=whisper-large-v3

# --- TTS voices (backend, optional) ---
# HOST_A_VOICE=en-US-GuyNeural
# HOST_B_VOICE=en-US-JennyNeural

# --- Auth (backend, optional) ---
# SECRET_KEY=change-me-for-production

# --- Frontend (Vite) ---
# Where the browser reaches the backend. The browser calls the backend
# DIRECTLY (CORS is enabled for localhost:3000) — generation takes ~110s
# and a dev proxy would drop that long socket.
VITE_API_BASE=http://127.0.0.1:8000
